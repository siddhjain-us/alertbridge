# Twilio (Sandbox / Trial)
# Get these from console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Claude API (required on Railway — replaces Ollama)
# Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Ollama (local dev only — not needed when ANTHROPIC_API_KEY is set)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional: LibreTranslate for zh/vi/ko (self-hosted)
LIBRETRANSLATE_URL=
LIBRETRANSLATE_LANGS=zh,vi,ko

# App
DEMO_MODE=true
PORT=3000
